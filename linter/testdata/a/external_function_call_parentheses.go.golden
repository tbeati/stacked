func functionCallParenthesesAssignmentExternal() {
	var err error
	_ = err

	err = stacked.Wrap((os.Chdir("/"))) // want "^error returned by os.Chdir is not wrapped with stacked$"
	err = stacked.Wrap((os.Chdir("/")))

	_, err = 0, stacked.Wrap((os.Chdir("/"))) // want "^error returned by os.Chdir is not wrapped with stacked$"
	_, err = 0, stacked.Wrap((os.Chdir("/")))

	_, err = stacked.Wrap2((os.Hostname())) // want "^error returned by os.Hostname is not wrapped with stacked$"
	_, err = stacked.Wrap2((os.Hostname()))

	_, _, err = stacked.Wrap3((os.Pipe())) // want "^error returned by os.Pipe is not wrapped with stacked$"
	_, _, err = stacked.Wrap3((os.Pipe()))
}

