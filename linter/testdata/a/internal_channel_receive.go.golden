func channelReceiveAssignmentInternal() {
	var err error
	var ok bool
	_, _ = err, ok

	err = stacked.Wrap(<-errChan) // want "^error received from errChan is not wrapped with stacked$"
	err = stacked.Wrap(<-errChan)

	_, err = 0, stacked.Wrap(<-errChan) // want "^error received from errChan is not wrapped with stacked$"
	_, err = 0, stacked.Wrap(<-errChan)

	err, ok = <-errChan // want "^error received from errChan is not wrapped with stacked$"
}

