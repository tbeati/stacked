func localFunctionCallAssignmentExternal() {
	localFunc := os.Chdir
	localFunc2 := os.Hostname
	localFunc3 := os.Pipe

	var err error
	_ = err

	err = stacked.Wrap(localFunc("/"))
	err = stacked.Wrap(localFunc("/"))

	_, err = 0, stacked.Wrap(localFunc("/"))
	_, err = 0, stacked.Wrap(localFunc("/"))

	_, err = stacked.Wrap2(localFunc2())
	_, err = stacked.Wrap2(localFunc2())

	_, _, err = stacked.Wrap3(localFunc3())
	_, _, err = stacked.Wrap3(localFunc3())
}

