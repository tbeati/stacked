func methodCallAssignmentExternal() {
	var err error
	_ = err
	var conn *net.UDPConn

	err = stacked.Wrap(conn.Close())
	err = stacked.Wrap(conn.Close())

	_, err = 0, stacked.Wrap(conn.Close())
	_, err = 0, stacked.Wrap(conn.Close())

	_, err = stacked.Wrap2(conn.File())
	_, err = stacked.Wrap2(conn.File())

	_, _, _, _, err = stacked.Wrap5(conn.ReadMsgUDPAddrPort(nil, nil))
	_, _, _, _, err = stacked.Wrap5(conn.ReadMsgUDPAddrPort(nil, nil))
}

