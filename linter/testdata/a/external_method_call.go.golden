func methodCallCompositeLiteralExternal() {
	var file *os.File

	_ = structWithErrorField{
		err: stacked.Wrap(file.Chdir()),
	}
	_ = structWithErrorField{
		err: stacked.Wrap(file.Chdir()),
	}

	_ = []error{stacked.Wrap(file.Chdir())}
	_ = []error{stacked.Wrap(file.Chdir())}

	_ = map[string]error{"": stacked.Wrap(file.Chdir())}
	_ = map[string]error{"": stacked.Wrap(file.Chdir())}
}

