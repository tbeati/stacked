func iteratorPullGenerated() {
	var err error
	_ = err

	var seq iter.Seq[error]
	next, _ := iter.Pull(seq)
	err, _ = stacked.WrapPull(next()) // want "^error returned by next is not wrapped with stacked$"
	err, _ = stacked.WrapPull(next())

	var seq2 iter.Seq2[int, error]
	_ = seq2
	next2, _ := iter.Pull2(seq2)
	_, err, _ = stacked.WrapPull2(next2()) // want "^error returned by next2 is not wrapped with stacked$"
	_, err, _ = stacked.WrapPull2(next2())
}
