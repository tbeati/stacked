func assignmentGenerated() {
	var err error
	_ = err

	err = stacked.Wrap(GenSingleReturn()) // want "^error returned by GenSingleReturn is not wrapped with stacked$"
	err = stacked.Wrap(GenSingleReturn())

	err = stacked.Wrap(generated.SingleReturn()) // want "^error returned by generated.SingleReturn is not wrapped with stacked$"
	err = stacked.Wrap(generated.SingleReturn())

	_, err = stacked.Wrap2(generated.MultipleReturn()) // want "^error returned by generated.MultipleReturn is not wrapped with stacked$"
	_, err = stacked.Wrap2(generated.MultipleReturn())

	localFuncSingle := generated.SingleReturn
	err = stacked.Wrap(localFuncSingle()) // want "^error returned by localFuncSingle is not wrapped with stacked$"
	err = stacked.Wrap(localFuncSingle())

	localFuncMultiple := generated.MultipleReturn
	_, err = stacked.Wrap2(localFuncMultiple()) // want "^error returned by localFuncMultiple is not wrapped with stacked$"
	_, err = stacked.Wrap2(localFuncMultiple())

	s := generated.StructWithMethods{}
	err = stacked.Wrap(s.SingleReturn()) // want "^error returned by s.SingleReturn is not wrapped with stacked$"
	err = stacked.Wrap(s.SingleReturn())

	_, err = stacked.Wrap2(s.MultipleReturn()) // want "^error returned by s.MultipleReturn is not wrapped with stacked$"
	_, err = stacked.Wrap2(s.MultipleReturn())

	var i generated.Interface
	err = stacked.Wrap(i.SingleReturn()) // want "^error returned by i.SingleReturn is not wrapped with stacked$"
	err = stacked.Wrap(i.SingleReturn())
	_, err = stacked.Wrap2(i.MultipleReturn()) // want "^error returned by i.MultipleReturn is not wrapped with stacked$"
	_, err = stacked.Wrap2(i.MultipleReturn())

	err = stacked.Wrap(generated.ErrGlobal) // want "^generated.ErrGlobal is not wrapped with stacked$"
	err = stacked.Wrap(generated.ErrGlobal)

	err = stacked.Wrap(generated.StringError("error")) // want "^value converted to error type generated.StringError is not wrapped with stacked$"
	err = stacked.Wrap(generated.StringError("error"))

	err = stacked.Wrap(generated.StructError{Message: "error"}) // want "^generated.StructError literal is not wrapped with stacked$"
	err = stacked.Wrap(generated.StructError{Message: "error"})

	err = stacked.Wrap(&generated.StructError{Message: "error"}) // want "^generated.StructError literal is not wrapped with stacked$"
	err = stacked.Wrap(&generated.StructError{Message: "error"})

	err = stacked.Wrap(generated.ReturnConcreteType()) // want "^error returned by generated.ReturnConcreteType is not wrapped with stacked$"
	err = stacked.Wrap(generated.ReturnConcreteType())
	err = stacked.Wrap(generated.ReturnConcreteTypePointer()) // want "^error returned by generated.ReturnConcreteTypePointer is not wrapped with stacked$"
	err = stacked.Wrap(generated.ReturnConcreteTypePointer())

	err = stacked.Wrap(generated.ErrGlobalConcreteType) // want "^generated.ErrGlobalConcreteType is not wrapped with stacked$"
	err = stacked.Wrap(generated.ErrGlobalConcreteType)
	err = stacked.Wrap(generated.ErrGlobalConcreteTypePointer) // want "^generated.ErrGlobalConcreteTypePointer is not wrapped with stacked$"
	err = stacked.Wrap(generated.ErrGlobalConcreteTypePointer)
	err = &generated.ErrGlobalConcreteType
	err = *generated.ErrGlobalConcreteTypePointer
}

func iteratorGenerated() {
	var seq iter.Seq[error]
	_ = seq

	seq = generated.Seq

	for range stacked.WrapSeq(seq) { // want "^seq is not wrapped with stacked$"
	}
	for range stacked.WrapSeq(seq) {
	}

	for range stacked.WrapSeq(generated.Seq) { // want "^generated.Seq is not wrapped with stacked$"
	}
	for range stacked.WrapSeq(generated.Seq) {
	}

	for range stacked.WrapSeq(generated.Iterator()) { // want "^iterator returned by generated.Iterator is not wrapped with stacked$"
	}
	for range stacked.WrapSeq(generated.Iterator()) {
	}

	for range stacked.WrapSeq(func(yield func(err error) bool) {}) { // want "^iterator literal is not wrapped with stacked$"
	}
	for range stacked.WrapSeq(func(yield func(err error) bool) {}) {
	}

	seqPointer := &seq
	for range stacked.WrapSeq(*seqPointer) { // want "^*seqPointer is not wrapped with stacked$"
	}
	for range stacked.WrapSeq(*seqPointer) {
	}

	var iterChan chan iter.Seq[error]
	for range stacked.WrapSeq(<-iterChan) { // want "^iterator received from iterChan is not wrapped with stacked$"
	}
	for range stacked.WrapSeq(<-iterChan) {
	}

	var seq2 iter.Seq2[int, error]
	_ = seq2

	seq2 = generated.Seq2

	for range stacked.WrapSeq2(seq2) { // want "^seq2 is not wrapped with stacked$"
	}
	for range stacked.WrapSeq2(seq2) {
	}

	for range stacked.WrapSeq2(generated.Seq2) { // want "^generated.Seq2 is not wrapped with stacked$"
	}
	for range stacked.WrapSeq2(generated.Seq2) {
	}

	for range stacked.WrapSeq2(generated.Iterator2()) { // want "^iterator returned by generated.Iterator2 is not wrapped with stacked$"
	}
	for range stacked.WrapSeq2(generated.Iterator2()) {
	}

	for range stacked.WrapSeq2(func(yield func(n int, err error) bool) {}) { // want "^iterator literal is not wrapped with stacked$"
	}
	for range stacked.WrapSeq2(func(yield func(n int, err error) bool) {}) {
	}
