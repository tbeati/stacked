package a

import (
	"errors"
	"fmt"
	"io/fs"

	"github.com/tbeati/stacked"
	"testdata/generated"
)

func assignmentIgnoredFunction() {
	var err error
	_ = err

	err = generated.SingleReturn() //stacked:disable
	err = generated.SingleReturn() // other comment //stacked:disable

	err = generated.IgnoredFunction(err)

	s := generated.IgnoredStruct{}
	err = s.IgnoredMethod(err)
	err = (&s).IgnoredMethod(err)

	var i generated.IgnoredInterface
	err = stacked.Wrap(i.IgnoredMethod())

	err = fmt.Errorf("wrapping %w", err)
	err = stacked.Wrap(fmt.Errorf("not wrapping"))

	err = errors.Join(err)
	err = errors.Unwrap(err)
}

func errorCheckFunctions() {
	var err error
	errors.Is(err, fs.ErrNotExist)
	errors.Is(err, (fs.ErrNotExist))
	errors.As(err, &fs.PathError{})
}
